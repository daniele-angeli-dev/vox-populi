# ── Model provider ────────────────────────────────────────────────────────────
# Supported: anthropic | openai | google-genai | groq | ollama | …
# See requirements.txt for the matching langchain-* package to install.
MODEL_PROVIDER=anthropic

# ── Model name ────────────────────────────────────────────────────────────────
# Anthropic examples:
MODEL=claude-sonnet-4-6
#MODEL=claude-haiku-3-5

# OpenAI examples:
#MODEL_PROVIDER=openai
#MODEL=gpt-4o
#MODEL=gpt-4o-mini

# Groq examples:
#MODEL_PROVIDER=groq
#MODEL=llama-3.3-70b-versatile

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
#OPENAI_API_KEY=your-openai-key-here
#GROQ_API_KEY=your-groq-key-here
